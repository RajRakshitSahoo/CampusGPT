{
  "folders": [
    { "name": "CampusGPT Root", "path": "." },
    { "name": "Backend (FastAPI)", "path": "backend" },
    { "name": "Frontend (React)", "path": "frontend" }
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "python.defaultInterpreterPath": "${workspaceFolder:Backend (FastAPI)}/venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "files.associations": { "*.jsx": "javascriptreact" },
    "emmet.includeLanguages": { "javascriptreact": "html" },
    "editor.quickSuggestions": { "strings": true },
    "terminal.integrated.defaultProfile.windows": "Command Prompt"
  },
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "bradlc.vscode-tailwindcss",
      "ms-azuretools.vscode-docker",
      "humao.rest-client"
    ]
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "FastAPI Backend",
        "type": "python",
        "request": "launch",
        "module": "uvicorn",
        "args": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
        "cwd": "${workspaceFolder:Backend (FastAPI)}",
        "envFile": "${workspaceFolder:Backend (FastAPI)}/.env",
        "console": "integratedTerminal"
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Start Backend",
        "type": "shell",
        "command": "cd backend && venv\\Scripts\\activate && uvicorn main:app --reload --port 8000",
        "group": "build",
        "presentation": { "reveal": "always", "panel": "new" }
      },
      {
        "label": "Start Frontend",
        "type": "shell",
        "command": "cd frontend && npm run dev",
        "group": "build",
        "presentation": { "reveal": "always", "panel": "new" }
      }
    ]
  }
}
